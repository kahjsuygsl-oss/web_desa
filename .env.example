# ---------- 1. DATA BACKEND ----------
# Pilih backend data: supabase atau apps_script
DATA_BACKEND=supabase

# Supabase (jika DATA_BACKEND=supabase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Google Apps Script (jika DATA_BACKEND=apps_script)
# URL Web App hasil Deploy di Apps Script (berakhiran /exec)
APPS_SCRIPT_URL=
# Token rahasia — HARUS SAMA dengan var TOKEN di file apps-script/Code.gs
APPS_SCRIPT_TOKEN=

# ---------- 2. SUPABASE STORAGE (penyimpanan gambar & dokumen) ----------
# Bucket publik yang menampung file upload.
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=images

# ---------- 3. ADMIN (hanya untuk app admin) ----------
ADMIN_PASSWORD=
SESSION_SECRET=

# ---------- 4. CACHE & REVALIDATE ----------
# Hanya app PUBLIK: lama cache data (detik). Lokal 0; Vercel publik 600.
DATA_REVALIDATE=0
REVALIDATE_SECRET=

# ---------- 5. URL SITUS ----------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
