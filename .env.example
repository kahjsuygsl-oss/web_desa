# ---------- 1. GOOGLE APPS SCRIPT (backend Sheets) ----------
# URL Web App hasil Deploy di Apps Script (berakhiran /exec)
APPS_SCRIPT_URL=
# Token rahasia — HARUS SAMA dengan var TOKEN di file apps-script/Code.gs
APPS_SCRIPT_TOKEN=

# ---------- 2. CLOUDINARY (penyimpanan gambar & dokumen) ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ---------- 3. ADMIN (hanya untuk app admin) ----------
ADMIN_PASSWORD=
SESSION_SECRET=

# ---------- 4. CACHE & REVALIDATE ----------
# Hanya app PUBLIK: lama cache data (detik). Lokal 0; Vercel publik 600.
DATA_REVALIDATE=0
REVALIDATE_SECRET=

# ---------- 5. URL SITUS ----------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
